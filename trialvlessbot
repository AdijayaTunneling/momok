#!/bin/bash
# trialvlessbot — Non-interaktif trial VLESS WS untuk bot
set -euo pipefail

domain="$(cat /etc/xray/domain)"
IP="$(curl -sS ipv4.icanhazip.com)"
rand=$(shuf -i 1000-9999 -n 1)
user="${LOGIN_OVERRIDE:-Trial-VL${rand}}"
uuid="$(cat /proc/sys/kernel/random/uuid)"
masaaktif="${DAYS:-1}"
minutes="${MINUTES:-15}"

exp="$(date -d "${masaaktif} days" +"%Y-%m-%d")"
sed -i '/#vless$/a\### '"$user $exp"'\
},{"id": "'"$uuid"'","email": "'"$user"'"' /etc/xray/config.json
sed -i '/#vlessgrpc$/a\### '"$user $exp"'\
},{"id": "'"$uuid"'","email": "'"$user"'"' /etc/xray/config.json

systemctl restart xray > /dev/null 2>&1 || true

mkdir -p /etc/kyt/limit/vless/ip
echo "1" > /etc/kyt/limit/vless/ip/$user
mkdir -p /etc/vless
echo "$((2 * 1024 * 1024 * 1024))" > /etc/vless/$user
echo "### $user $exp 2 1" >> /etc/vless/.vless.db

port_tls=443
port_ntls=80

link_tls="vless://${uuid}@${domain}:${port_tls}?path=/vless&security=tls&encryption=none&type=ws&host=${domain}&sni=${domain}#${user}"
