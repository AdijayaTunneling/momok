#!/bin/bash
# trialvlessbot — Non-interaktif trial VLESS WS untuk bot
set -euo pipefail

domain="$(cat /etc/xray/domain)"
IP="$(curl -sS ipv4.icanhazip.com)"
rand=$(shuf -i 1000-9999 -n 1)
user="${LOGIN_OVERRIDE:-Trial-VL${rand}}"
uuid="$(cat /proc/sys/kernel/random/uuid)"
masaaktif="${DAYS:-1}"
minutes="${MINUTES:-15}"

exp="$(date -d "${masaaktif} days" +"%Y-%m-%d")"
sed -i '/#vless$/a\### '"$user $exp"'\
},{"id": "'"$uuid"'","email": "'"$user"'"' /etc/xray/config.json
sed -i '/#vlessgrpc$/a\### '"$user $exp"'\
},{"id": "'"$uuid"'","email": "'"$user"'"' /etc/xray/config.json

systemctl restart xray > /dev/null 2>&1 || true

mkdir -p /etc/kyt/limit/vless/ip
echo "1" > /etc/kyt/limit/vless/ip/$user
mkdir -p /etc/vless
echo "$((2 * 1024 * 1024 * 1024))" > /etc/vless/$user
echo "### $user $exp 2 1" >> /etc/vless/.vless.db

port_tls=443
port_ntls=80

link_tls="vless://${uuid}@${domain}:${port_tls}?path=/vless&security=tls&encryption=none&type=ws&host=${domain}&sni=${domain}#${user}"
link_ntls="vless://${uuid}@${domain}:${port_ntls}?path=/vless&security=none&encryption=none&type=ws&host=${domain}#${user}"

echo "tunnel vless ${user}" | at now + ${minutes} minutes &> /dev/null || true

echo "===OUTPUT1==="
echo "══════════════════════"
echo "✅ TRIAL VLESS BERHASIL"
echo "══════════════════════"
echo "Host : $domain"
echo "User   : $user"
echo "UUID   : $uuid"
echo "Expired: ${minutes} Menit"
echo "══════════════════════"
echo "<b>LINK VLESS TLS :</b>"
echo "<pre>$link_tls</pre>"
echo "<b>LINK VLESS nTLS :</b>"
echo "<pre>$link_ntls</pre>"
echo "===OUTPUT2==="
echo "<pre>$link_tls</pre>"

BOT_TOKEN_TRX="8220003675:AAH3Kc8DpW-pklkQZ3FJ7Eei19lfUvj7ofU"
CHAT_ID_TRX="@adijayavpn"
TRX_MSG="┏━━━━━━━━❖━━━━━━━━┓
┃ 🛎️ NEW TRANSACTION
┗━━━━━━━━❖━━━━━━━━┛
 𖤓 LEASEWEB SINGAPORE
 𖤓 City : $(curl -s ipinfo.io/city )
 𖤓 Name : ${user}
 𖤓 Jenis : TRIAL VLESS
 𖤓 Ip Limit : 1 IP
 𖤓 Expired : ${minutes} Menit
┏━━━━━━━━❖━━━━━━━━┓
┃ Bot @adijayavpnpanelbot
┗━━━━━━━━❖━━━━━━━━┛"
curl -s -X POST "https://api.telegram.org/bot${BOT_TOKEN_TRX}/sendMessage" \
     -d "chat_id=${CHAT_ID_TRX}" \
     -d "text=${TRX_MSG}" >/dev/null

exit 0
