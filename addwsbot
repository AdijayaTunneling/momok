#!/bin/bash
# addwsbot - safe insert vmess user (#vmess & #vmessgrpc)
# Usage: addwsbot <username> <quota_GB> <iplimit> <exp_days>
set -euo pipefail

username_raw=${1:-}
quota=${2:-0}
iplimit=${3:-1}
exp_days=${4:-1}

if [[ -z "$username_raw" ]]; then
  echo "Usage: $0 <username> <quota_GB> <iplimit> <exp_days>"
  exit 2
fi

# sanitize username
username=$(printf "%s" "$username_raw" | tr -d '"\\')
exp_date=$(date -d "$exp_days days" +"%Y-%m-%d" 2>/dev/null || date +"%Y-%m-%d")
uuid=$(cat /proc/sys/kernel/random/uuid 2>/dev/null || uuidgen)

config_file="/etc/xray/config.json"

if [[ ! -f "$config_file" ]]; then
  echo "ERROR: $config_file tidak ditemukan"
  exit 3
fi

# backup
bak="${config_file}.bak.$(date +%s)"
cp -a "$config_file" "$bak" || { echo "ERROR: gagal backup $config_file"; exit 4; }

insert_after_marker_sed() {
  local marker="$1"
  if ! grep -qF "$marker" "$config_file"; then
    echo "marker '$marker' tidak ditemukan — skip"
    return 0
  fi

  if sed -n "/$marker/,/\]/p" "$config_file" | grep -q "\"email\": \"$username\""; then
    echo "user '$username' sudah ada di $marker — skip"
    return 0
  fi

  # Tambahkan user → TANPA tanda } di ujung (sesuai gaya bawaan)
  sed -i '/'"$marker"'$/a\### '"$username $exp_date"'\
},{"id": "'"$uuid"'","alterId": 0,"email": "'"$username"'"' "$config_file"
}

# hanya markers yang benar-benar ada
for m in "#vmess" "#vmessgrpc"; do
  insert_after_marker_sed "$m"
done

# Validasi config
if command -v xray >/dev/null 2>&1; then
  if ! xray run -test -config "$config_file" >/dev/null 2>&1; then
    echo "ERROR: config.json invalid -> rollback ke $bak"
    mv -f "$bak" "$config_file"
    exit 6
  fi
  echo "xray test ok"
else
  echo "WARNING: xray binary not found, skip test"
fi

# restart xray
systemctl restart xray || echo "WARNING: gagal restart xray"

# setup quota & ip limit
mkdir -p /etc/vmess
if [[ $iplimit -gt 0 ]]; then
  mkdir -p /etc/kyt/limit/vmess/ip
  echo "$iplimit" > /etc/kyt/limit/vmess/ip/$username
fi
qclean=$(echo "$quota" | sed 's/[^0-9]*//g')
qbytes=$(( qclean * 1024 * 1024 * 1024 ))
if [[ $qclean -gt 0 ]]; then
  echo "$qbytes" > /etc/vmess/$username
fi
dbentry=$(grep "^###" /etc/vmess/.vmess.db 2>/dev/null | grep -w "$username" | awk '{print $2}' || true)
if [[ -n "$dbentry" ]]; then
  sed -i "/\b$username\b/d" /etc/vmess/.vmess.db
fi
echo "### $username $exp_date $uuid $quota $iplimit" >> /etc/vmess/.vmess.db

# buat link vmess
domain=$(cat /etc/xray/domain 2>/dev/null || echo "yourdomain.com")
port_tls=443
port_ntls=80
port_grpc=443

json_base_tls=$(printf '{"v":"2","ps":"%s-tls","add":"%s","port":"%s","id":"%s","aid":"0","net":"ws","type":"none","host":"%s","path":"/vmess","tls":"tls"}' \
  "$username" "$domain" "$port_tls" "$uuid" "$domain" | base64 -w0)

json_base_ntls=$(printf '{"v":"2","ps":"%s-ntls","add":"%s","port":"%s","id":"%s","aid":"0","net":"ws","type":"none","host":"%s","path":"/vmess","tls":"none"}' \
  "$username" "$domain" "$port_ntls" "$uuid" "$domain" | base64 -w0)

json_base_grpc=$(printf '{"v":"2","ps":"%s-tls","add":"%s","port":"%s","id":"%s","aid":"0","net":"ws","type":"none","host":"%s","path":"/vmess","tls":"tls"}' \
  "$username" "support.zoom.us" "$port_grpc" "$uuid" "support.zoom.us.$domain" | base64 -w0)

link_tls="vmess://$json_base_tls"
link_ntls="vmess://$json_base_ntls"
link_grpc="vmess://$json_base_grpc"

# ==========================
# TLS Bug Host tambahan (tidak menyentuh config.json)
# ==========================
json_tls_ilped=$(printf '{"v":"2","ps":"%s-ilped","add":"%s","port":"%s","id":"%s","aid":"0","net":"ws","type":"none","host":"%s","path":"/vmess","tls":"tls","sni":"%s"}' \
  "$username" "api.quipper.com" "$port_tls" "$uuid" "api.quipper.com.$domain" "api.quipper.com.$domain" | base64 -w0)
link_tls_ilped="vmess://$json_tls_ilped"

json_tls_gamemax=$(printf '{"v":"2","ps":"%s-gamemax","add":"%s","port":"%s","id":"%s","aid":"0","net":"ws","type":"none","host":"%s","path":"/vmess","tls":"tls","sni":"%s"}' \
  "$username" "ir.huya.com" "$port_tls" "$uuid" "$domain" "$domain" | base64 -w0)
link_tls_gamemax="vmess://$json_tls_gamemax"

json_tls_fun=$(printf '{"v":"2","ps":"%s-fun","add":"%s","port":"%s","id":"%s","aid":"0","net":"ws","type":"none","host":"%s","path":"/vmess","tls":"tls","sni":"%s"}' \
  "$username" "creativeservices.netflix.com" "$port_tls" "$uuid" "$domain" "$domain" | base64 -w0)
link_tls_fun="vmess://$json_tls_fun"

json_tls_iflix=$(printf '{"v":"2","ps":"%s-iflix","add":"%s","port":"%s","id":"%s","aid":"0","net":"ws","type":"none","host":"%s","path":"/vmess","tls":"tls","sni":"%s"}' \
  "$username" "$domain" "$port_tls" "$uuid" "$domain" "live.iflix.com" | base64 -w0)
link_tls_iflix="vmess://$json_tls_iflix"

json_tls_edu=$(printf '{"v":"2","ps":"%s-edu","add":"%s","port":"%s","id":"%s","aid":"0","net":"ws","type":"none","host":"%s","path":"/vmess","tls":"tls","sni":"%s"}' \
  "$username" "support.udemy.com" "$port_tls" "$uuid" "$domain" "$domain" | base64 -w0)
link_tls_edu="vmess://$json_tls_edu"

# // Get Bot (notif detail akun ke admin)
CHATID=$(grep -E "^#bot# " "/etc/bot/.bot.db" | cut -d ' ' -f 3)
KEY=$(grep -E "^#bot# " "/etc/bot/.bot.db" | cut -d ' ' -f 2)
URL="https://api.telegram.org/bot$KEY/sendMessage"

TEXT="
⚪══════════════════⚪
    Create VMESS Success
⚪══════════════════⚪
