#!/bin/bash

#addtrbot - safe insert trojan user (#trojanws & #trojangrpc)
#Usage: addtrbot <username> <quota_GB> <iplimit> <exp_days>

set -euo pipefail

username_raw=${1:-}
quota=${2:-0}
iplimit=${3:-1}
exp_days=${4:-1}

if [[ -z "$username_raw" ]]; then
    echo "Usage: $0 <username> <quota_GB> <iplimit> <exp_days>"
    exit 2
fi

username=$(printf "%s" "$username_raw" | tr -d '"')
exp_date=$(date -d "$exp_days days" +"%Y-%m-%d" 2>/dev/null || date +"%Y-%m-%d")
uuid=$(cat /proc/sys/kernel/random/uuid 2>/dev/null || uuidgen)

config_file="/etc/xray/config.json"

if [[ ! -f "$config_file" ]]; then
    echo "ERROR: $config_file tidak ditemukan"
    exit 3
fi

bak="${config_file}.bak.$(date +%s)"
cp -a "$config_file" "$bak" || {
    echo "ERROR: gagal backup $config_file"
    exit 4
}

insert_after_marker_sed() {
    local marker="$1"

    if ! grep -qF "$marker" "$config_file"; then
        echo "marker '$marker' tidak ditemukan — skip"
        return 0
    fi

    if sed -n "/$marker/,/\]/p" "$config_file" | grep -q "\"email\": \"$username\""; then
        echo "user '$username' sudah ada di $marker — skip"
        return 0
    fi

    # Gunakan awk untuk insert yang lebih reliable
    awk -v marker="$marker" -v comment="#! $username $exp_date" -v obj="},{\"password\": \"$uuid\",\"email\": \"$username\"" '
    {
        print
        if ($0 == marker) {
            print comment
            print obj
        }
    }' "$config_file" > "${config_file}.tmp"

    mv "${config_file}.tmp" "$config_file"
}

#inject ws + grpc
for m in "#trojanws" "#trojangrpc"; do
    insert_after_marker_sed "$m"
done

#validate config
if command -v xray >/dev/null 2>&1; then
    if ! xray run -test -config "$config_file" >/dev/null 2>&1; then
        echo "ERROR: config.json invalid -> rollback ke $bak"
        mv -f "$bak" "$config_file"
        exit 6
    fi
    echo "xray test ok"
else
    echo "WARNING: xray binary not found, skip test"
fi

#restart xray
systemctl restart xray || echo "WARNING: gagal restart xray"

# setup quota & ip limit
mkdir -p /etc/trojan
if [[ $iplimit -gt 0 ]]; then
  mkdir -p /etc/kyt/limit/trojan/ip
  echo "$iplimit" > /etc/kyt/limit/trojan/ip/$username
fi
qclean=$(echo "$quota" | sed 's/[^0-9]*//g')
qbytes=$(( qclean * 1024 * 1024 * 1024 ))
if [[ $qclean -gt 0 ]]; then
  echo "$qbytes" > /etc/trojan/$username
fi
dbentry=$(grep "^###" /etc/trojan/.trojan.db 2>/dev/null | grep -w "$username" | awk '{print $2}' || true)
if [[ -n "$dbentry" ]]; then
  sed -i "/\b$username\b/d" /etc/trojan/.trojan.db
fi
echo "### $username $exp_date $uuid $quota $iplimit" >> /etc/trojan/.trojan.db

