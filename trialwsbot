#!/bin/bash
# trialwsbot — Non-interaktif trial VMess WS untuk bot
set -euo pipefail

domain="$(cat /etc/xray/domain)"
IP="$(curl -sS ipv4.icanhazip.com)"
rand=$(shuf -i 1000-9999 -n 1)
user="${LOGIN_OVERRIDE:-Trial-VM${rand}}"
uuid="$(cat /proc/sys/kernel/random/uuid)"
masaaktif="${DAYS:-1}"
minutes="${MINUTES:-15}"

exp="$(date -d "${masaaktif} days" +"%Y-%m-%d")"
sed -i '/#vmess$/a\### '"$user $exp"'\
},{"id": "'""$uuid""'","alterId": 0,"email": "'""$user""'"' /etc/xray/config.json
sed -i '/#vmessgrpc$/a\### '"$user $exp"'\
},{"id": "'""$uuid""'","alterId": 0,"email": "'""$user""'"' /etc/xray/config.json

systemctl restart xray > /dev/null 2>&1 || true

mkdir -p /etc/kyt/limit/vmess/ip
echo "1" > /etc/kyt/limit/vmess/ip/$user
mkdir -p /etc/vmess
echo "$((2 * 1024 * 1024 * 1024))" > /etc/vmess/$user
echo "### $user $exp 2 1" >> /etc/vmess/.vmess.db

port_tls=443
port_ntls=80

json_tls=$(printf '{"v":"2","ps":"%s","add":"%s","port":"%s","id":"%s","aid":"0","net":"ws","type":"none","host":"%s","path":"/vmess","tls":"tls"}' \
  "$user" "$domain" "$port_tls" "$uuid" "$domain" | base64 -w0)
json_ntls=$(printf '{"v":"2","ps":"%s","add":"%s","port":"%s","id":"%s","aid":"0","net":"ws","type":"none","host":"%s","path":"/vmess","tls":"none"}' \
  "$user" "$domain" "$port_ntls" "$uuid" "$domain" | base64 -w0)

link_tls="vmess://$json_tls"
link_ntls="vmess://$json_ntls"

# ==========================
# TLS Bug Host tambahan (tidak menyentuh config.json)
# ==========================
json_tls_ilped=$(printf '{"v":"2","ps":"%s-ilped","add":"%s","port":"%s","id":"%s","aid":"0","net":"ws","type":"none","host":"%s","path":"/vmess","tls":"tls","sni":"%s"}' \
  "$user" "api.quipper.com" "$port_tls" "$uuid" "api.quipper.com.$domain" "api.quipper.com.$domain" | base64 -w0)
link_tls_ilped="vmess://$json_tls_ilped"

json_tls_gamemax=$(printf '{"v":"2","ps":"%s-gamemax","add":"%s","port":"%s","id":"%s","aid":"0","net":"ws","type":"none","host":"%s","path":"/vmess","tls":"tls","sni":"%s"}' \
  "$user" "ir.huya.com" "$port_tls" "$uuid" "$domain" "$domain" | base64 -w0)
link_tls_gamemax="vmess://$json_tls_gamemax"

json_tls_fun=$(printf '{"v":"2","ps":"%s-fun","add":"%s","port":"%s","id":"%s","aid":"0","net":"ws","type":"none","host":"%s","path":"/vmess","tls":"tls","sni":"%s"}' \
  "$user" "creativeservices.netflix.com" "$port_tls" "$uuid" "$domain" "$domain" | base64 -w0)
link_tls_fun="vmess://$json_tls_fun"

json_tls_iflix=$(printf '{"v":"2","ps":"%s-iflix","add":"%s","port":"%s","id":"%s","aid":"0","net":"ws","type":"none","host":"%s","path":"/vmess","tls":"tls","sni":"%s"}' \
  "$user" "$domain" "$port_tls" "$uuid" "$domain" "live.iflix.com" | base64 -w0)
link_tls_iflix="vmess://$json_tls_iflix"

json_tls_edu=$(printf '{"v":"2","ps":"%s-edu","add":"%s","port":"%s","id":"%s","aid":"0","net":"ws","type":"none","host":"%s","path":"/vmess","tls":"tls","sni":"%s"}' \
  "$user" "support.udemy.com" "$port_tls" "$uuid" "$domain" "$domain" | base64 -w0)
link_tls_edu="vmess://$json_tls_edu"

json_base_grpc=$(printf '{"v":"2","ps":"%s-tls","add":"%s","port":"%s","id":"%s","aid":"0","net":"ws","type":"none","host":"%s","path":"/vmess","tls":"tls"}' \
  "$user" "support.zoom.us" "$port_tls" "$uuid" "support.zoom.us.$domain" | base64 -w0)
link_grpc="vmess://$json_base_grpc"

echo "tunnel vmess ${user}" | at now + ${minutes} minutes &> /dev/null || true

echo "===OUTPUT1==="
echo "══════════════════════"
echo "✅ TRIAL VMESS BERHASIL"
echo "══════════════════════"
echo "Host : $domain"
echo "User   : $user"
echo "UUID   : $uuid"
echo "Expired: ${minutes} Menit"
echo "══════════════════════"
echo "<b>LINK VMESS nTLS :</b>"
echo "<pre>$link_ntls</pre>"
echo "<b>TLS ILPED :</b>"
echo "non-aktifkan fitur jagapulsa"
echo "<pre>$link_tls_ilped</pre>"
echo "<b>TLS GAMEMAX :</b>"
echo "<pre>$link_tls_gamemax</pre>"
echo "<b>TLS IM3 APPS FUN :</b>"
echo "<pre>$link_tls_fun</pre>"
echo "<b>TLS IFLIX :</b>"
echo "<pre>$link_tls_iflix</pre>"
echo "<b>TLS EDU TIMUR :</b>"
echo "Khusus selain jabar, jakarta, banten & sumatra"
echo "<pre>$link_tls_edu</pre>"
echo "<b>TLS CONFERENCE :</b>"
echo "<pre>$link_grpc</pre>"
echo "===OUTPUT2==="
echo "<b>LINK  TLS :</b>"
echo "<pre>$link_tls</pre>"

