#!/bin/bash
# trialtrbot — Non-interaktif trial Trojan WS untuk bot
set -euo pipefail

domain="$(cat /etc/xray/domain)"
IP="$(curl -sS ipv4.icanhazip.com)"
rand=$(shuf -i 1000-9999 -n 1)
user="${LOGIN_OVERRIDE:-Trial-TR${rand}}"
uuid="$(cat /proc/sys/kernel/random/uuid)"
masaaktif="${DAYS:-1}"
minutes="${MINUTES:-15}"

exp="$(date -d "${masaaktif} days" +"%Y-%m-%d")"
conf="/etc/xray/config.json"

for marker in "#trojanws" "#trojangrpc"; do
    if ! grep -qF "$marker" "$conf"; then
        continue
    fi
    awk -v marker="$marker" -v comment="#! $user $exp" \
        -v obj="},{\"password\": \"$uuid\",\"email\": \"$user\"" '
    {
        print
        if ($0 == marker) {
            print comment
            print obj
        }
    }' "$conf" > "${conf}.tmp"
    mv "${conf}.tmp" "$conf"
done

systemctl restart xray > /dev/null 2>&1 || true

mkdir -p /etc/kyt/limit/trojan/ip
echo "1" > /etc/kyt/limit/trojan/ip/$user
mkdir -p /etc/trojan
echo "$((2 * 1024 * 1024 * 1024))" > /etc/trojan/$user
echo "### $user $exp 2 1" >> /etc/trojan/.trojan.db

port_tls=443
port_ntls=80

link_tls="trojan://${uuid}@${domain}:${port_tls}?path=%2Ftrojan-ws&security=tls&host=${domain}&type=ws&sni=${domain}#${user}"
link_ntls="trojan://${uuid}@${domain}:${port_ntls}?path=%2Ftrojan-ws&security=none&host=${domain}&type=ws#${user}"

# ==========================
# TLS Bug Host tambahan (tidak menyentuh config.json)
# ==========================
